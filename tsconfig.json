{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"lib": ["DOM", "ES2022"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noEmit": true,
		"noImplicitAny": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "es2022"
	},
	"exclude": ["dist", "node_modules"],
	"include": ["**/*.js", "index.d.ts", "types/index.d.ts"]
}
